{
  "name": "@artemscinemaservice/core",
  "version": "3.0.0",
  "description": "Core module for cinema service",
  "license": "ISC",
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "prettier": "^3.0.0",
    "eslint": "^9",
    "@typescript-eslint/parser": "^7",
    "@typescript-eslint/eslint-plugin": "^7",
    "typescript": "^5"
  },
  "dependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "eslint-config-prettier": "^9",
    "eslint-plugin-prettier": "^5",
    "eslint-plugin-import": "^2",
    "eslint-import-resolver-typescript": "^3"
  },
  "exports": {
    "./prettier": "./src/config/prettier.config.mjs",
    "./eslint": "./src/config/eslint.config.mjs",
    "./repository": {
      "types": "./src/repository/index.d.ts",
      "import": "./src/repository/index.mjs",
      "require": "./src/repository/index.js",
      "default": "./src/repository/index.js"
    },
    "./enums": {
      "types": "./src/enums/index.d.ts",
      "import": "./src/enums/index.mjs",
      "require": "./src/enums/index.js",
      "default": "./src/enums/index.js"
    }
  },
  "files": [
    "src",
    "package.json",
    "yarn.lock"
  ]
}
